    "\n",
    "import sqlite3\n",
    "conn = sqlite3.connect(r'D:\\theGist\\data\\thegist.db')\n",
    "rows = conn.execute('SELECT label, COUNT(*) FROM idea_labels GROUP BY label').fetchall()\n",
    "for label, count in rows:\n",
    "    name = 'Relevant' if label == 1 else 'Irrelevant'\n",
    "    print(f'{name}: {count}')"
   ]
  }
